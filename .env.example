# ── Command Centre (app.phantix.site) ────────────────────────────────────────
# Live API. When unset, the app runs on the bundled demo tenant.
# Even when set, visitors can enter the demo via app.phantix.site/demo or ?demo=1
# and switch to their real organization from the demo banner.
# VITE_API_BASE=https://staging.phantix.site/api/v1

# Cross-surface links (production defaults shown)
# VITE_LANDING_URL=https://phantix.site
# VITE_PLATFORM_URL=https://platform.phantix.site
# VITE_APP_URL=https://app.phantix.site
