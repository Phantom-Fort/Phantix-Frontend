# ── Command Centre (app.phantix.site) ────────────────────────────────────────
# Live-by-default. Set VITE_API_BASE so product pages call the real API.
# Demo tenant (Acme mocks) only when: API unset, OR visitor opens /demo or ?demo=1.
VITE_API_BASE=https://staging.phantix.site/api/v1

